# DeployOps Console — environment variables
#
# Copy this file to .env.local for local development. Never commit .env files.
# Every variable is required at runtime; the app fails fast on startup if any
# is missing or malformed (see src/lib/env.ts).

# Neon Postgres pooled connection string. Use the "Pooled connection" string
# from the Neon dashboard (it ends in -pooler.<region>.aws.neon.tech). The
# app talks to Neon over the @neondatabase/serverless HTTP driver.
DATABASE_URL=postgresql://user:password@ep-example-pooler.us-east-1.aws.neon.tech/deployops?sslmode=require

# NextAuth (Auth.js v5) signing secret. Generate with: openssl rand -base64 32
NEXTAUTH_SECRET=replace-with-32-byte-base64-secret

# Canonical app URL. http://localhost:3000 in dev, your prod URL in prod.
NEXTAUTH_URL=http://localhost:3000

# GitHub OAuth App credentials used ONLY for operator sign-in. This is NOT the
# GitHub App that will be used to read repos in Session 2 — keep them separate.
# Create at: https://github.com/settings/developers (OAuth Apps → New OAuth App).
# Authorization callback URL must be: <NEXTAUTH_URL>/api/auth/callback/github
GITHUB_OAUTH_CLIENT_ID=
GITHUB_OAUTH_CLIENT_SECRET=

# Single-user allowlist. Set this to the GitHub email address of the operator
# (the email returned by the GitHub /user API for the signed-in user). Sign-in
# attempts from any other email are rejected.
ALLOWED_EMAIL=you@example.com

# 32-byte symmetric key (base64) used by Session 2 onwards to encrypt provider
# credentials at rest. Generate with: openssl rand -base64 32
# Validated at startup but unused by Session 1 code paths.
ENCRYPTION_KEY=replace-with-32-byte-base64-key

# Global kill switch. 0 = dry-run only (Session 1 default). When Session 5+
# wires live provider mutations, flipping this to 1 plus per-provider live
# mode is required to actually call GitHub/Vercel/Neon APIs.
DEPLOYOPS_LIVE=0
